# Recommended runtime tweaks for broader coverage and 4yr targeting
# Set precision profile to `wide` to increase recall; change to `balanced` or `strict` for stricter filtering
PRECISION_PROFILE=wide
# Relax strict title-only filtering (any value other than 'developer_strict' will skip strict checks)
SALESFORCE_ROLE_MODE=relaxed
# Minimum resume match score to alert (0-100)
ALERT_MIN_MATCH_SCORE=30
# Maximum alert items per run (use 'all' for no limit)
ALERT_MAX_ITEMS=50
# Increase Naukri fetch limits if you want more coverage
NAUKRI_MAX_UNIQUE_RESULTS=300
NAUKRI_MAX_ITEMS_PER_PLAN=200
